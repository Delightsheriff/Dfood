# ============================================================================
# Dfood Monorepo — Root Environment Variables
# ============================================================================
# Copy to .env and fill in your values.
# ============================================================================

# ---- All Apps ----
NODE_ENV=development

# ---- API (apps/api) ----
PORT=4000
MONGODB_URI=mongodb://localhost:27017/food-api

# Auth
JWT_SECRET=your-super-secret-key-min-32-chars-long-change-this
JWT_EXPIRE=7d

# Redis (optional — caching)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Paystack (payments)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Resend Email
RESEND_API_KEY=
EMAIL_FROM=DFood <noreply@dfood.com>

# Firebase (optional — push notifications)
FIREBASE_SERVICE_ACCOUNT=

# ---- Admin (apps/admin) ----
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001

# ---- Mobile (apps/mobile) ----
EXPO_PUBLIC_API_URL=http://localhost:4000/api
EXPO_PUBLIC_PAYSTACK_KEY=
