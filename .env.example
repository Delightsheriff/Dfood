# ============================================================================
# Dfood Monorepo - Environment Variables
# ============================================================================
# Copy this file to .env at the monorepo root.
# Apps read these via their respective configs (Next.js, Expo, etc.)
# ============================================================================

# ---- API (apps/api) ----
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=

# Email
RESEND_API_KEY=

# ---- Admin (apps/admin) ----
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001

# ---- Mobile (apps/mobile) ----
EXPO_PUBLIC_API_URL=http://localhost:3000
